FROM node:20.19-alpine AS build

WORKDIR /app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

ARG VITE_APP_NAME
ARG VITE_API_BASE_URL
ARG VITE_API_TIMEOUT_MS
ARG VITE_REALTIME_BASE_URL
ARG VITE_REALTIME_RECONNECT_DELAY_MS
ARG VITE_REALTIME_DEFAULT_TRANSPORT

ENV VITE_APP_NAME=$VITE_APP_NAME
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_API_TIMEOUT_MS=$VITE_API_TIMEOUT_MS
ENV VITE_REALTIME_BASE_URL=$VITE_REALTIME_BASE_URL
ENV VITE_REALTIME_RECONNECT_DELAY_MS=$VITE_REALTIME_RECONNECT_DELAY_MS
ENV VITE_REALTIME_DEFAULT_TRANSPORT=$VITE_REALTIME_DEFAULT_TRANSPORT

RUN pnpm run build

FROM nginx:1.29-alpine AS runtime

ENV PORT=3000

COPY nginx/default.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 3000
