	"definitions": {
		"file.Visibility": {
			"type": "string",
			"enum": ["private", "public"],
			"x-enum-varnames": ["VisibilityPrivate", "VisibilityPublic"]
		},
		"handlers.AuthResponse": {
			"type": "object",
			"properties": {
				"accessToken": {
					"type": "string"
				},
				"expiresAt": {
					"type": "string",
					"example": "2026-03-16T18:00:00Z"
				},
				"refreshToken": {
					"type": "string"
				},
				"user": {
					"$ref": "#/definitions/presenter.UserResponse"
				}
			}
		},
		"handlers.ErrorResponse": {
			"type": "object",
			"properties": {
				"error": {
					"type": "string",
					"example": "validation error"
				}
			}
		},
		"handlers.ForgotPasswordRequest": {
			"type": "object",
			"required": ["email"],
			"properties": {
				"email": {
					"type": "string",
					"example": "jane@example.com"
				}
			}
		},
		"handlers.HealthResponse": {
			"type": "object",
			"properties": {
				"services": {
					"type": "object",
					"additionalProperties": {
						"$ref": "#/definitions/handlers.ServiceInfo"
					}
				},
				"status": {
					"type": "string",
					"example": "ok"
				}
			}
		},
		"handlers.LoginChallengeResponse": {
			"type": "object",
			"properties": {
				"email": {
					"type": "string"
				},
				"message": {
					"type": "string"
				},
				"otpExpiresAt": {
					"type": "string"
				}
			}
		},
		"handlers.LoginRequest": {
